// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`TodoView > matches snapshot with empty todos 1`] = `"<div class="workspace-content-wide"><div class="page-header page-header-sticky"><button class="btn-back mb-md">← Back</button><div class="page-header-row"><div><h2>TODO</h2><p class="page-subtitle">0 Pending · 0 Completed</p></div><div data-testid="header-actions"><button data-testid="add-todo-btn">Add</button><button data-testid="select-btn">Select</button></div></div></div><div data-testid="todo-tabs"><button data-testid="tab-pending" class="active">Pending</button><button data-testid="tab-completed" class="">Completed</button><button data-testid="tab-archived" class="">Archived</button></div><div data-testid="due-filter-bar"></div><div data-testid="progress-summary"></div><div data-testid="todo-list" data-count="0"></div></div>"`;

exports[`TodoView > matches snapshot with todos 1`] = `"<div class="workspace-content-wide"><div class="page-header page-header-sticky"><button class="btn-back mb-md">← Back</button><div class="page-header-row"><div><h2>TODO</h2><p class="page-subtitle">1 Pending · 1 Completed</p></div><div data-testid="header-actions"><button data-testid="add-todo-btn">Add</button><button data-testid="select-btn">Select</button></div></div></div><div data-testid="todo-tabs"><button data-testid="tab-pending" class="active">Pending</button><button data-testid="tab-completed" class="">Completed</button><button data-testid="tab-archived" class="">Archived</button></div><div data-testid="due-filter-bar"></div><div data-testid="progress-summary"></div><div data-testid="todo-list" data-count="1"></div></div>"`;
