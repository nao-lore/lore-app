// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`DashboardView > matches snapshot with data 1`] = `"<div class="workspace-content-wide"><div class="text-center mt-xl" style="margin-bottom: 36px;"><div class="font-extrabold" style="font-size: 32px; color: var(--text-secondary); line-height: 1.2;">Good morning!</div></div><div data-testid="nudge-cards"></div><div class="mb-2xl"><div class="section-header"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-play" aria-hidden="true" style="opacity: 0.5;"><path d="M9 9.003a1 1 0 0 1 1.517-.859l4.997 2.997a1 1 0 0 1 0 1.718l-4.997 2.997A1 1 0 0 1 9 14.996z"></path><circle cx="12" cy="12" r="10"></circle></svg>Recent projects</div><div class="flex" style="gap: 12px; overflow-x: auto; overflow-y: hidden; padding-bottom: 8px; margin-bottom: -8px;"><button type="button" aria-label="Open project: Test Project" style="min-width: 160px; max-width: 280px; padding: 16px 20px; border-radius: 12px; cursor: pointer; background: var(--card-bg); border: 1px solid var(--border-subtle); transition: all 0.15s ease; flex: 1 0 160px; text-align: left;" class="project-snap-card"><div style="font-size: 24px; margin-bottom: 10px; line-height: 1;">📂</div><div class="truncate font-semibold text-sm text-secondary" style="margin-bottom: 4px;">Test Project</div><div class="flex-row" style="gap: 6px; margin-top: 6px;"><div class="progress-bar-mini"><div class="progress-bar-mini-fill" style="background: var(--accent); width: 0%;"></div></div><span class="shrink-0" style="font-size: 10px; color: var(--text-placeholder);">0/2</span></div></button><button type="button" aria-label="Create new log" style="min-width: 100px; padding: 16px 20px; border-radius: 12px; cursor: pointer; border: 1px dashed var(--border-subtle); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; color: var(--text-placeholder); transition: all 0.15s ease; flex-shrink: 0;" class="new-log-card"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus" aria-hidden="true"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg><span class="fs-11 font-semibold">New</span></button></div></div><div class="mb-2xl"><div class="section-header"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square" aria-hidden="true" style="opacity: 0.5;"><rect width="18" height="18" x="3" y="3" rx="2"></rect></svg>Today's Focus<span class="badge badge-accent font-bold" style="font-size: 11px; margin-left: 4px;">2</span><span class="ml-auto" style="font-size: 11px; color: var(--text-placeholder);">0/2</span></div><div class="flex-col gap-xs"><button type="button" aria-label="Toggle action: Deploy to prod" style="gap: 10px; padding: 10px 14px; border-radius: 10px; cursor: pointer; font-size: 13px; line-height: 1.5; background: var(--card-bg); border: 1px solid var(--border-subtle); user-select: none; transition: all 0.12s ease; text-align: left; width: 100%;" class="focus-task-item flex-row"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square shrink-0" aria-hidden="true" style="color: var(--text-placeholder);"><rect width="18" height="18" x="3" y="3" rx="2"></rect></svg><span class="flex-1" style="color: var(--text-body); overflow-wrap: break-word; word-break: break-word;">Deploy to prod</span><span class="badge badge-accent shrink-0" style="border-radius: 4px;">Test Project</span></button><button type="button" aria-label="Toggle action: Write tests" style="gap: 10px; padding: 10px 14px; border-radius: 10px; cursor: pointer; font-size: 13px; line-height: 1.5; background: var(--card-bg); border: 1px solid var(--border-subtle); user-select: none; transition: all 0.12s ease; text-align: left; width: 100%;" class="focus-task-item flex-row"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square shrink-0" aria-hidden="true" style="color: var(--text-placeholder);"><rect width="18" height="18" x="3" y="3" rx="2"></rect></svg><span class="flex-1" style="color: var(--text-body); overflow-wrap: break-word; word-break: break-word;">Write tests</span><span class="badge badge-accent shrink-0" style="border-radius: 4px;">Test Project</span></button></div></div><div data-testid="activity-summary"></div><div class="mb-2xl"><button class="btn" style="display: flex; align-items: center; gap: 6px; font-size: 13px;"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text" aria-hidden="true"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"></path><path d="M14 2v5a1 1 0 0 0 1 1h5"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path></svg>View Weekly Report</button></div><div data-testid="trends-section"></div></div>"`;

exports[`DashboardView > matches snapshot with empty state 1`] = `"<div class="workspace-content-wide flex-col items-center"><div class="text-center font-extrabold" style="font-size: 28px; color: var(--text-secondary); margin-top: 80px; margin-bottom: 16px;">Good morning!</div><div class="empty-state"><div class="empty-state-icon"><div data-testid="empty-dashboard-icon"></div></div><p class="font-semibold" style="font-size: 20px;">Create your first Snapshot</p><p class="page-subtitle" style="max-width: 360px; margin: 8px auto 0px;">Paste an AI conversation to auto-structure it into status, decisions, TODOs, and next actions. Classify logs into projects to generate Project Summaries and Knowledge Bases — making handoffs and reviews effortless.</p><div class="dashboard-steps"><div class="dashboard-step"><span class="dashboard-step-num">1</span><span class="dashboard-step-text">Copy an AI chat</span></div><div class="dashboard-step"><span class="dashboard-step-num">2</span><span class="dashboard-step-text">Paste it here</span></div><div class="dashboard-step"><span class="dashboard-step-num">3</span><span class="dashboard-step-text">TODOs &amp; decisions extracted</span></div></div><button class="btn btn-primary mt-lg" style="font-size: 16px; padding: 12px 28px;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus" aria-hidden="true"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>Create your first Snapshot</button></div></div>"`;
