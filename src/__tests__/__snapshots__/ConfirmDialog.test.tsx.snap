// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ConfirmDialog > matches snapshot (danger mode) 1`] = `"<div class="modal-overlay" role="presentation"><div class="confirm-dialog" role="alertdialog" aria-modal="true" aria-labelledby="confirm-dialog-title" aria-describedby="confirm-dialog-desc"><div class="confirm-dialog-title" id="confirm-dialog-title">Delete this item?</div><div class="confirm-dialog-desc" id="confirm-dialog-desc">This action cannot be undone.</div><div class="confirm-dialog-actions"><button class="btn">Cancel</button><button class="btn btn-danger">Delete</button></div></div></div>"`;

exports[`ConfirmDialog > matches snapshot (non-danger mode) 1`] = `"<div class="modal-overlay" role="presentation"><div class="confirm-dialog" role="alertdialog" aria-modal="true" aria-labelledby="confirm-dialog-title" aria-describedby="confirm-dialog-desc"><div class="confirm-dialog-title" id="confirm-dialog-title">Delete this item?</div><div class="confirm-dialog-desc" id="confirm-dialog-desc">This action cannot be undone.</div><div class="confirm-dialog-actions"><button class="btn">Cancel</button><button class="btn btn-primary">Delete</button></div></div></div>"`;

exports[`ConfirmDialog > matches snapshot without description 1`] = `"<div class="modal-overlay" role="presentation"><div class="confirm-dialog" role="alertdialog" aria-modal="true" aria-labelledby="confirm-dialog-title"><div class="confirm-dialog-title" id="confirm-dialog-title">Delete this item?</div><div class="confirm-dialog-actions"><button class="btn">Cancel</button><button class="btn btn-danger">Delete</button></div></div></div>"`;
