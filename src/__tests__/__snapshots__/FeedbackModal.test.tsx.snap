// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`FeedbackModal > matches snapshot in initial state 1`] = `"<div class="modal-overlay" role="presentation"><div class="onboarding-card max-w-480" role="dialog" aria-modal="true" aria-label="Feedback" style="width: 90vw;"><div class="feedback-header"><h2 class="feedback-title">Feedback</h2><button class="btn" style="padding: 4px;" aria-label="Close"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x" aria-hidden="true"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg></button></div><div class="mb-lg"><label class="feedback-label">Category</label><div class="flex flex-wrap gap-2"><button class="seg-control-btn btn-pill active-worklog" style="padding: 5px 12px;">Bug Report</button><button class="seg-control-btn btn-pill" style="padding: 5px 12px;">Feature Request</button><button class="seg-control-btn btn-pill" style="padding: 5px 12px;">UX / Usability</button><button class="seg-control-btn btn-pill" style="padding: 5px 12px;">Other</button></div></div><div class="mb-lg"><label class="feedback-label">Details</label><textarea placeholder="Describe the bug, feature idea, or share your thoughts..." aria-label="Details" class="feedback-textarea"></textarea></div><div class="flex justify-end gap-3"><button class="btn btn-nav-sm" disabled="" style="padding: 6px 16px;">Copy</button><button class="btn btn-primary btn-md-action" disabled="">Submit via GitHub</button></div><p class="feedback-note">Requires a GitHub account. If you don't have one, use "Copy" and send via email or DM.</p></div></div>"`;
