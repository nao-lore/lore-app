// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`InputView — snapshots > matches snapshot in default state 1`] = `
"<div class="workspace-content-centered"><h1 class="text-center input-greeting">Good morning!</h1><div class="input-card-hero relative"><textarea class="input-card-textarea" aria-label="Paste your AI conversation here, or try a sample →" placeholder="Paste your AI conversation here, or try a sample →" style="opacity: 1;"></textarea><div class="flex-row justify-between input-bottom-bar"><div></div></div><div class="flex-row gap-xs input-transform-area"><span class="input-usage-counter">Free trial: NaN days remaining</span><button class="btn btn-primary btn-transform" disabled="" style="opacity: 0.35;">Create Snapshot + TODO</button></div></div><div class="input-toolbar"><div class="input-toolbar-row"><div class="mode-selector" role="radiogroup" aria-label="Transform mode"><button class="mode-selector-btn mode-primary" role="radio" aria-checked="false" title="Generate context snapshot from AI conversation
Structures your AI conversation into a context snapshot">Context Snapshot</button><button class="mode-selector-btn active mode-secondary" role="radio" aria-checked="true" title="Generate snapshot and TODOs together
Creates a snapshot and extracts TODOs at the same time">Snapshot + TODO</button><button class="mode-selector-btn mode-secondary" role="radio" aria-checked="false" title="Extract only the TODO list
Extracts only the TODO list from the conversation">TODO Only</button></div><div class="project-dropdown"><button class="input input-sm input-select-compact project-dropdown-trigger" aria-label="Select project" aria-expanded="false" aria-haspopup="listbox" type="button"><span class="project-dropdown-label">Select project</span><span class="project-dropdown-arrow" aria-hidden="true">▾</span></button></div><input accept=".txt,.md,.docx,.json" multiple="" aria-label="Select file" class="input-file-hidden" type="file"><button class="input input-sm input-import-btn">+ Import File</button></div></div></div>"
`;

