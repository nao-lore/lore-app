{
  "name": "Lore",
  "short_name": "Lore",
  "description": "Turn AI conversations into structured work logs and handoff notes. Capture threads from ChatGPT, Claude, and Gemini automatically.",
  "start_url": "/",
  "id": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#0e0e10",
  "theme_color": "#7c5cfc",
  "categories": ["productivity", "utilities"],
  "icons": [
    { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "text": "text"
    }
  },
  "shortcuts": [
    {
      "name": "New Snapshot",
      "short_name": "New",
      "url": "/?action=new",
      "icons": [{"src": "/favicon-32.png", "sizes": "32x32"}]
    }
  ],
  "screenshots": [
    {
      "src": "/docs/screenshots/home-input.png",
      "sizes": "1370x890",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Home screen with AI conversation input and handoff creation"
    },
    {
      "src": "/docs/screenshots/dashboard.png",
      "sizes": "730x480",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard with today's focus, projects, and activity trends"
    },
    {
      "src": "/docs/screenshots/timeline.png",
      "sizes": "730x480",
