# Lore - Environment Variables
# Copy this file to .env and fill in your values.

# Built-in AI API (server-side Gemini proxy)
# Set this on Vercel: Settings > Environment Variables
# Get a free key at https://aistudio.google.com
GEMINI_API_KEY=

# The only Vite env flags used are built-ins (e.g. import.meta.env.DEV).
# Users can also configure their own API keys in the app's Settings UI (BYOK).
