{
  "manifest_version": 3,
  "name": "Lore — AI Context Sync",
  "version": "0.2.0",
  "description": "Capture AI conversations and inject project context. Your AI sessions never start from zero again.",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://loresync.dev/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://claude.ai/*", "*://chatgpt.com/*", "*://chat.openai.com/*", "*://gemini.google.com/*"],
      "js": ["content-banner.js"],
      "css": ["content-banner.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://loresync.dev/*"],
      "js": ["content-lore-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "author": "Lore",
  "minimum_chrome_version": "116"
}
